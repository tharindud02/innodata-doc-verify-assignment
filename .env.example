# Postgres (used by docker-compose for the postgres service)
POSTGRES_USER=docverify
POSTGRES_PASSWORD=docverify_dev
POSTGRES_DB=docverify

# Backend (local dev; docker-compose overrides DATABASE_URL and REDIS_* for containers)
DATABASE_URL=postgresql://docverify:docverify_dev@localhost:5432/docverify
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=change-me-min-16-chars
JWT_EXPIRES_IN=1d
BACKEND_PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
DEDUP_WINDOW_MS=300000
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
SEED_USER_EMAIL=tharindud02@gmail.com
SEED_USER_PASSWORD=tharindu1234

# Frontend (local Vite only; Docker Compose always uses http://backend:3001)
VITE_DEV_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:3001
